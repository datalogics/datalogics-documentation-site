# Auto-detect text files and normalize line endings to LF on all platforms
* text=auto

# Explicitly set LF for source and content files
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binaries — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.pdf binary
*.zip binary
*.node binary
